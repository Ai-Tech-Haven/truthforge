# TruthForge Configuration Template
# Copy this file to .env and fill in your actual values

# ============================================
# Hedera Configuration
# ============================================
# Your Hedera account ID (format: 0.0.xxxxx)
HEDERA_ACCOUNT_ID=0.0.7974354

# Your Hedera private key (DER encoded)
HEDERA_PRIVATE_KEY=3030020100300706052b8104000a04220420f2898f6397f83bf1eb38da89a735325aba3a50aa26601dcd62e0f7ff3261a39a

# Hedera network: testnet or mainnet
HEDERA_NETWORK=testnet

# HCS Topic ID for agent messaging (you'll need to create this on Hedera)
HCS_TOPIC_ID=

# HOL Registry endpoint URL
HOL_REGISTRY_ENDPOINT=https://hol-registry.testnet.hashgraph.io

# HOL Registry Broker API Key
# Get this from: https://portal.hashgraphonline.com/account/api-keys
# Navigate to: Account > API Keys > Create New Key
REGISTRY_BROKER_API_KEY=

# ============================================
# WooCommerce Configuration
# ============================================
# Your WooCommerce store URL (e.g., https://www.a-thi.online)
WOOCOMMERCE_STORE_URL=https://your-store.com

# WooCommerce REST API consumer key
WOOCOMMERCE_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WooCommerce REST API consumer secret
WOOCOMMERCE_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Enable WooCommerce integration (true/false)
WOOCOMMERCE_ENABLED=false

# WooCommerce webhook secret for signature validation
WOOCOMMERCE_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================
# FedEx Configuration
# ============================================
# FedEx API key
FEDEX_API_KEY=your_fedex_api_key

# FedEx secret key
FEDEX_SECRET_KEY=your_fedex_secret_key

# FedEx account number
FEDEX_ACCOUNT_NUMBER=123456789

# FedEx environment (sandbox or production)
FEDEX_ENVIRONMENT=sandbox

# ============================================
# System Configuration
# ============================================
# Enable mock mode for development (true/false)
# When true, no real blockchain transactions or API calls are made
MOCK_MODE=true

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# API server port
PORT=5000

# Maximum retry attempts for failed operations
MAX_RETRIES=3

# Request timeout in seconds
TIMEOUT_SECONDS=30

# Enable debug mode (true/false)
DEBUG=false

# ============================================
# Agent Configuration
# ============================================
# HBAR amount for agent staking
AGENT_STAKE_AMOUNT=100

# Prefix for HCS topic memos
HCS_TOPIC_MEMO_PREFIX=HCS-10:TRUTHFORGE:

# ============================================
# TruthForge Settings
# ============================================
# Maximum image size in MB
MAX_IMAGE_SIZE_MB=10

# Supported image file types (comma-separated)
SUPPORTED_IMAGE_TYPES=jpg,png,pdf

# Deepfake detection threshold (0.0 to 1.0)
DEEPFAKE_DETECTION_THRESHOLD=0.75

# ============================================
# API Authentication (Optional)
# ============================================
# API authentication token for protected endpoints
API_AUTH_TOKEN=your_secure_token_here
